# =============================================================================
# AIBAA Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---- LLM API Keys -----------------------------------------------------------
# Primary: Google Gemini 2.5 Flash
GEMINI_API_KEY=

# Fallback: NVIDIA NIM (DeepSeek via OpenAI-compatible endpoint)
NVIDIA_API_KEY=

# ---- Authentication ---------------------------------------------------------
# Generate a secure secret: openssl rand -hex 32
AIBAA_JWT_SECRET=change-me-in-production

# HS256 (default) or RS256 (for JWKS/external IdP)
AIBAA_JWT_ALGORITHM=HS256

# Dev-mode bootstrap token (disabled in production)
AIBAA_DEV_AUTH_ENABLED=true
AIBAA_DEV_BOOTSTRAP_TOKEN=dev-bootstrap-token

# Default tenant and user IDs for dev (multi-tenant will override these)
AIBAA_DEFAULT_TENANT_ID=default-tenant
AIBAA_DEFAULT_USER_ID=default-user
AIBAA_DEFAULT_USER_ROLE=analyst

# ---- Database ---------------------------------------------------------------
# SQLite (default for local dev):
DATABASE_URL=sqlite:///./aibaa.db

# PostgreSQL (for Docker / production):
# DATABASE_URL=postgresql://aibaa:secret@localhost:5432/aibaa

# ---- CORS -------------------------------------------------------------------
AIBAA_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# ---- Environment ------------------------------------------------------------
AIBAA_ENV=development

# ---- File Upload Limits -----------------------------------------------------
MAX_UPLOAD_MB=150
AIBAA_MAX_PARSED_CHARS=1200000

# ---- LLM Backend Override (for CI/testing) ----------------------------------
# Set to "mock" to use pre-defined fixture responses without API calls
# LLM_BACKEND=mock
